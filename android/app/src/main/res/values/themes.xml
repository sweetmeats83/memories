<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Memories" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="colorSecondary">@color/brand</item>
        <item name="android:statusBarColor">@color/brand</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.Memories.Fullscreen" parent="Theme.Memories">
